{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wefest",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "@tanstack/react-start/server-entry",
  "build": {
    "command": "bun run build"
  },
  "assets": {
    "directory": ".output/public",
    "binding": "ASSETS"
  }
}
