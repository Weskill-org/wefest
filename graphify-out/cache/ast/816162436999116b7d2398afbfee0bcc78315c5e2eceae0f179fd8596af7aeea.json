\src\\routes\\organizer.events.$eventId.tsx", "source_location": "L253"}, {"caller_nid": "routes_organizer_events_eventid_organizereventdashboard", "callee": "toLocaleString", "is_member_call": true, "source_file": "C:\\Users\\sharm\\OneDrive\\Documents\\GitHub\\wefest\\src\\routes\\organizer.events.$eventId.tsx", "source_location": "L267"}, {"caller_nid": "routes_organizer_events_eventid_organizereventdashboard", "callee": "(() => {\r\n                  if (!tickets || tickets.length === 0) {\r\n                    return <div className=\"flex h-full items-center justify-center text-muted-foreground text-sm\">No sales data yet.</div>;\r\n                  }\r\n                  \r\n                  // Group by date\r\n                  const last7Days = eachDayOfInterval({ start: subDays(new Date(), 6), end: new Date() }).map(d => format(d, \"MMM dd\"));\r\n                  const salesByDate = tickets.reduce((acc: any, t: any) => {\r\n                    const dateStr = format(parseISO(t.created_at), \"MMM dd\");\r\n                    acc[dateStr] = (acc[dateStr] || 0) + 1;\r\n                    return acc;\r\n                  }, {});\r\n                  \r\n                  const chartData = last7Days.map(date => ({\r\n                    date,\r\n                    sales: salesByDate[date] || 0\r\n                  }));\r\n\r\n                  return (\r\n                    <ResponsiveContainer width=\"100%\" height=\"100%\">\r\n                      <AreaChart data={chartData}>\r\n                        <defs>\r\n                          <linearGradient id=\"colorSales\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\r\n                            <stop offset=\"5%\" stopColor=\"hsl(var(--primary))\" stopOpacity={0.5}/>\r\n                            <stop offset=\"95%\" stopColor=\"hsl(var(--primary))\" stopOpacity={0}/>\r\n                          </linearGradient>\r\n                        </defs>\r\n                        <XAxis dataKey=\"date\" stroke=