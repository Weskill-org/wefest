a = last7Days.map(date => ({\r\n                    date,\r\n                    scans: scansByDate[date] || 0\r\n                  }));\r\n\r\n                  return (\r\n                    <ResponsiveContainer width=\"100%\" height=\"100%\">\r\n                      <BarChart data={chartData}>\r\n                        <XAxis dataKey=\"date\" stroke=\"hsl(var(--muted-foreground))\" fontSize={12} tickLine={false} axisLine={false} />\r\n                        <YAxis stroke=\"hsl(var(--muted-foreground))\" fontSize={12} tickLine={false} axisLine={false} allowDecimals={false} />\r\n                        <Tooltip \r\n                          contentStyle={{ backgroundColor: \"hsl(var(--background))\", borderRadius: \"12px\", border: \"1px solid hsl(var(--border))\" }}\r\n                          itemStyle={{ color: \"hsl(var(--foreground))\" }}\r\n                          cursor={{ fill: \"hsl(var(--muted))\", opacity: 0.4 }}\r\n                        />\r\n                        <Bar dataKey=\"scans\" fill=\"hsl(var(--primary))\" radius={[4, 4, 0, 0]} />\r\n                      </BarChart>\r\n                    </ResponsiveContainer>\r\n                  );\r\n                })", "is_member_call": false, "source_file": "C:\\Users\\sharm\\OneDrive\\Documents\\GitHub\\wefest\\src\\routes\\sponsor.dashboard.tsx", "source_location": "L427"}]}